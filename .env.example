# ============================================================
# Firebase Client SDK（VITE_ プレフィックス = ブラウザに公開される。公開可）
# Firebase コンソール > プロジェクト設定 > 全般 から取得
# ============================================================
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ============================================================
# Firebase エミュレータ（ローカル開発・課金不要）
# true にすると demo-goal-app 固定プロジェクトでローカル動作する。
# その場合、上の Firebase 設定値は使われない。
# ※ Anthropic キー（functions/.env）だけは本物が必要。
# ============================================================
VITE_USE_FIREBASE_EMULATOR=true
