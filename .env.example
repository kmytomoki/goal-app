# ============================================================
# Firebase エミュレータ（ローカル開発・課金不要）
# 使う場合は true にし、下の HOST 2つも設定する。
# このモードでは下の Firebase 各種設定値（apiKey 等）は使われず、
# demo-goal-app という固定プロジェクトでローカル動作する。
# ※ Anthropic キーだけは本物が必要（AI応答のため）。
# ============================================================
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8088
# FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099

# ============================================================
# Anthropic (AI) - サーバー側のみで使用。クライアントに露出させない
# ============================================================
ANTHROPIC_API_KEY=

# ============================================================
# Firebase Client SDK (公開可。ブラウザから利用される)
# Firebase コンソール > プロジェクト設定 > 全般 から取得
# ============================================================
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ============================================================
# Firebase Admin SDK (サーバー側のみ。秘密情報)
# サービスアカウントのJSONから転記する。
# private_key は \n を含む文字列をそのまま貼り付ける（ダブルクォートで囲む）
# ============================================================
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
